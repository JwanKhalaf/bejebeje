@using Humanizer
@model Bejebeje.Models.BbPoints.PublicProfileViewModel

@{
  ViewData["Title"] = $"{Model.Username}'s Profile";
  ViewData["Description"] = $"Public profile page for {Model.Username}.";
}

<div class="py-5 pr-4 mb-6">
  <nav aria-label="Breadcrumb" class="text-neutral-200 opacity-70 uppercase text-base">
    <a asp-controller="Profile" asp-action="Index">/ Profile</a>
    <span>/ @Model.Username</span>
  </nav>
</div>

@await Html.PartialAsync("_SearchForm")

<div class="mb-6">
  <h2 class="text-neutral-200 text-2xl font-semibold">@Model.Username</h2>
  <p class="text-amber-400 text-sm mt-1">@Model.ContributorLabel</p>
</div>

<div class="mb-8">
  <div class="flex gap-8 items-center">
    <div class="text-center">
      <p class="text-amber-400 text-3xl font-semibold">@(((double)Model.TotalPoints).ToMetric(decimals: 1))</p>
      <p class="text-neutral-400 text-xs uppercase mt-1">BB Points</p>
    </div>

    <div class="text-center">
      <p class="text-neutral-200 text-3xl font-semibold">@Model.ArtistsSubmittedCount</p>
      <p class="text-neutral-400 text-xs uppercase mt-1">Artists Submitted</p>
    </div>

    <div class="text-center">
      <p class="text-neutral-200 text-3xl font-semibold">@Model.LyricsSubmittedCount</p>
      <p class="text-neutral-400 text-xs uppercase mt-1">Lyrics Submitted</p>
    </div>
  </div>
</div>
