@using Humanizer
@model Bejebeje.Models.BbPoints.OwnProfileViewModel

@{
  ViewData["Title"] = "Your Profile";
  ViewData["Description"] = "The user profile page.";

  bool hasAnyPoints = Model.TotalPoints > 0;
  bool hasRecentActivity = Model.RecentActivity != null && Model.RecentActivity.Any();
}

<div class="py-5 pr-4 mb-6">
  <nav class="text-neutral-200 opacity-70 uppercase text-base">
    <a asp-controller="Profile" asp-action="Index">/ Profile</a>
  </nav>
</div>

@await Html.PartialAsync("_SearchForm")

@if (!string.IsNullOrEmpty(Model.Username))
{
  <div class="mb-6">
    <h2 class="text-neutral-200 text-2xl font-semibold">@Model.Username</h2>
    <p class="text-amber-400 text-sm mt-1">@Model.ContributorLabel</p>
  </div>
}

<div class="mb-8">
  <h3 class="text-neutral-200 text-xl font-semibold mb-4">BB Points Breakdown</h3>

  <div class="overflow-x-auto">
    <table class="w-full max-w-lg text-left text-sm">
      <thead>
        <tr class="border-b border-neutral-600">
          <th class="text-neutral-400 font-medium py-2 pr-4">Category</th>
          <th class="text-neutral-400 font-medium py-2 text-right">Points</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-neutral-700">
          <td class="text-neutral-300 py-2 pr-4">Artist Submissions</td>
          <td class="text-neutral-200 py-2 text-right">@Model.ArtistSubmissionPoints</td>
        </tr>
        <tr class="border-b border-neutral-700">
          <td class="text-neutral-300 py-2 pr-4">Artist Approvals</td>
          <td class="text-neutral-200 py-2 text-right">@Model.ArtistApprovalPoints</td>
        </tr>
        <tr class="border-b border-neutral-700">
          <td class="text-neutral-300 py-2 pr-4">Lyric Submissions</td>
          <td class="text-neutral-200 py-2 text-right">@Model.LyricSubmissionPoints</td>
        </tr>
        <tr class="border-b border-neutral-700">
          <td class="text-neutral-300 py-2 pr-4">Lyric Approvals</td>
          <td class="text-neutral-200 py-2 text-right">@Model.LyricApprovalPoints</td>
        </tr>
        <tr class="border-b border-neutral-700">
          <td class="text-neutral-300 py-2 pr-4">Report Submissions</td>
          <td class="text-neutral-200 py-2 text-right">@Model.ReportSubmissionPoints</td>
        </tr>
        <tr class="border-b border-neutral-700">
          <td class="text-neutral-300 py-2 pr-4">Report Acknowledgements</td>
          <td class="text-neutral-200 py-2 text-right">@Model.ReportAcknowledgementPoints</td>
        </tr>
        <tr class="border-b border-neutral-700">
          <td class="text-neutral-300 py-2 pr-4">Likes Given</td>
          <td class="text-neutral-200 py-2 text-right">@Model.LikePoints</td>
        </tr>
        <tr class="border-t-2 border-neutral-500">
          <td class="text-neutral-200 font-semibold py-2 pr-4">Total</td>
          <td class="text-amber-400 font-semibold py-2 text-right">@(((double)Model.TotalPoints).ToMetric(decimals: 1))</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<div class="mb-8">
  <h3 class="text-neutral-200 text-xl font-semibold mb-4">Recent Activity</h3>

  @if (!hasRecentActivity && !hasAnyPoints)
  {
    <p class="text-neutral-400 text-sm">
      You haven't earned any BB Points yet. Submit an artist or lyric to get started!
    </p>
  }
  else if (!hasRecentActivity && hasAnyPoints)
  {
    <p class="text-neutral-400 text-sm">
      Your historical contributions have been counted! New activity will appear here as you earn more points.
    </p>
  }
  else
  {
    <div class="space-y-3">
      @foreach (var activity in Model.RecentActivity)
      {
        <div class="flex items-center justify-between bg-neutral-700/50 rounded px-4 py-3">
          <div>
            <p class="text-neutral-200 text-sm">@activity.ActionDescription</p>
            <p class="text-neutral-400 text-xs">@activity.EntityName</p>
          </div>
          <div class="text-right">
            <p class="text-amber-400 text-sm font-semibold">+@activity.Points</p>
            <p class="text-neutral-500 text-xs">@activity.Date.ToString("d MMM yyyy")</p>
          </div>
        </div>
      }
    </div>
  }
</div>

<div class="mb-8">
  <h2 class="text-neutral-200 text-3xl font-semibold mb-4">Want to help?</h2>

  <p class="text-neutral-300 text-base/7 mb-6">First of all, thank you! Kurds now and in the future will be thankful. Please choose an action below.</p>

  <a asp-controller="Artist" asp-action="Create" class="inline-block text-neutral-200 font-semibold border border-neutral-600 rounded-md px-6 py-3 hover:bg-neutral-700 hover:text-red-500 transition-all duration-200 ease-in">Add a new artist</a>
</div>
