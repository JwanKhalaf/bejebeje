@model Bejebeje.Models.Account.ResetPasswordViewModel

@{
  ViewData["Title"] = "Reset password";
  ViewData["Description"] = "Set a new password for your Bejebeje account";
}

<div class="py-5 pr-4 mb-6">
  <nav class="text-neutral-200 opacity-70 uppercase text-base">
    / Reset password
  </nav>
</div>

<div class="pr-4 lg:pr-8 mb-8 max-w-md">
  <h1 class="font-lora text-neutral-200 text-3xl mb-2">
    Reset password
  </h1>

  <p class="text-neutral-400 text-sm mb-6">
    Enter the code sent to your email along with your new password.
  </p>

  @if (!string.IsNullOrEmpty(Model.ErrorMessage))
  {
    <div class="rounded-md bg-red-900/50 border border-red-700 p-4 mb-6">
      <p class="text-sm text-red-200">@Model.ErrorMessage</p>
    </div>
  }

  <form method="post" asp-action="ResetPassword">
    @Html.AntiForgeryToken()

    <div class="mb-4">
      <label for="email" class="block text-sm font-medium text-neutral-300 mb-1">Email</label>
      <input type="email" id="email" name="Email" value="@Model.Email" required
             class="w-full rounded-md bg-neutral-700 border border-neutral-600 text-neutral-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-500 focus:border-transparent" />
    </div>

    <div class="mb-4">
      <label for="code" class="block text-sm font-medium text-neutral-300 mb-1">Confirmation code</label>
      <input type="text" id="code" name="Code" value="@Model.Code" required autocomplete="one-time-code"
             class="w-full rounded-md bg-neutral-700 border border-neutral-600 text-neutral-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-500 focus:border-transparent" />
    </div>

    <div class="mb-4">
      <label for="newPassword" class="block text-sm font-medium text-neutral-300 mb-1">New password</label>
      <input type="password" id="newPassword" name="NewPassword" required
             class="w-full rounded-md bg-neutral-700 border border-neutral-600 text-neutral-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-500 focus:border-transparent" />

      <ul id="password-checklist" class="mt-2 text-xs text-neutral-400 space-y-1">
        <li id="check-length" class="flex items-center gap-1.5">
          <span class="inline-block size-1.5 rounded-full bg-neutral-600"></span>
          At least 14 characters
        </li>
        <li id="check-number" class="flex items-center gap-1.5">
          <span class="inline-block size-1.5 rounded-full bg-neutral-600"></span>
          At least 1 number
        </li>
        <li id="check-uppercase" class="flex items-center gap-1.5">
          <span class="inline-block size-1.5 rounded-full bg-neutral-600"></span>
          At least 1 uppercase letter
        </li>
        <li id="check-lowercase" class="flex items-center gap-1.5">
          <span class="inline-block size-1.5 rounded-full bg-neutral-600"></span>
          At least 1 lowercase letter
        </li>
      </ul>
    </div>

    <div class="mb-6">
      <label for="confirmPassword" class="block text-sm font-medium text-neutral-300 mb-1">Confirm new password</label>
      <input type="password" id="confirmPassword" name="ConfirmPassword" required
             class="w-full rounded-md bg-neutral-700 border border-neutral-600 text-neutral-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-500 focus:border-transparent" />
      <p id="password-match" class="mt-1 text-xs text-neutral-400 hidden">Passwords do not match</p>
    </div>

    <button type="submit" id="submit-btn" disabled
            class="w-full rounded-md bg-neutral-600 px-4 py-2 text-sm font-medium text-neutral-200 hover:bg-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-500 disabled:opacity-50 disabled:cursor-not-allowed">
      Reset password
    </button>
  </form>
</div>

@section Scripts {
  <script src="~/js/password-validation.js"></script>
  <script src="~/js/password-match.js"></script>
}
