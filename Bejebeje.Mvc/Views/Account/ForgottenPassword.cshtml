@model Bejebeje.Models.Account.ForgottenPasswordViewModel

@{
  ViewData["Title"] = "Forgotten password";
  ViewData["Description"] = "Reset your Bejebeje password";
}

<div class="py-5 pr-4 mb-6">
  <nav class="text-neutral-200 opacity-70 uppercase text-base">
    / Forgotten password
  </nav>
</div>

<div class="pr-4 lg:pr-8 mb-8 max-w-md">
  <h1 class="font-lora text-neutral-200 text-3xl mb-2">
    Forgotten password
  </h1>

  <p class="text-neutral-400 text-sm mb-6">
    Enter your email address and we'll send you a code to reset your password.
  </p>

  @if (!string.IsNullOrEmpty(Model.ErrorMessage))
  {
    <div class="rounded-md bg-red-900/50 border border-red-700 p-4 mb-6">
      <p class="text-sm text-red-200">@Model.ErrorMessage</p>
    </div>
  }

  <form method="post" asp-action="ForgottenPassword">
    @Html.AntiForgeryToken()

    <div class="mb-6">
      <label for="email" class="block text-sm font-medium text-neutral-300 mb-1">Email</label>
      <input type="email" id="email" name="Email" value="@Model.Email" required
             class="w-full rounded-md bg-neutral-700 border border-neutral-600 text-neutral-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-500 focus:border-transparent" />
    </div>

    <button type="submit"
            class="w-full rounded-md bg-neutral-600 px-4 py-2 text-sm font-medium text-neutral-200 hover:bg-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-500">
      Send reset code
    </button>
  </form>

  <div class="mt-6 text-sm text-neutral-400">
    <p>Remember your password? <a href="/login" class="text-neutral-200 underline hover:text-neutral-100">Log in</a></p>
  </div>
</div>
