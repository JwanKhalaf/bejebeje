@model Bejebeje.Models.Account.LoginViewModel

@{
  ViewData["Title"] = "Login";
  ViewData["Description"] = "Log in to Bejebeje";
}

<div class="py-5 pr-4 mb-6">
  <nav class="text-neutral-200 opacity-70 uppercase text-base">
    / Login
  </nav>
</div>

<div class="pr-4 lg:pr-8 mb-8 max-w-md">
  <h1 class="font-lora text-neutral-200 text-3xl mb-6">
    Log in
  </h1>

  @if (!string.IsNullOrEmpty(ViewData["SuccessMessage"] as string))
  {
    <div class="rounded-md bg-green-900/50 border border-green-700 p-4 mb-6">
      <p class="text-sm text-green-200">@ViewData["SuccessMessage"]</p>
    </div>
  }

  @if (!string.IsNullOrEmpty(Model.ErrorMessage))
  {
    <div class="rounded-md bg-red-900/50 border border-red-700 p-4 mb-6">
      <p class="text-sm text-red-200">@Model.ErrorMessage</p>
    </div>
  }

  <form method="post" asp-action="Login">
    @Html.AntiForgeryToken()
    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

    <div class="mb-4">
      <label for="email" class="block text-sm font-medium text-neutral-300 mb-1">Email</label>
      <input type="email" id="email" name="Email" value="@Model.Email" required
             class="w-full rounded-md bg-neutral-700 border border-neutral-600 text-neutral-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-500 focus:border-transparent" />
    </div>

    <div class="mb-4">
      <label for="password" class="block text-sm font-medium text-neutral-300 mb-1">Password</label>
      <input type="password" id="password" name="Password" required
             class="w-full rounded-md bg-neutral-700 border border-neutral-600 text-neutral-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-500 focus:border-transparent" />
    </div>

    <div class="mb-6 flex items-center gap-2">
      <input type="checkbox" id="rememberMe" name="RememberMe" value="true"
             class="rounded bg-neutral-700 border-neutral-600 text-neutral-500 focus:ring-neutral-500" />
      <label for="rememberMe" class="text-sm text-neutral-300">Remember me</label>
    </div>

    <button type="submit"
            class="w-full rounded-md bg-neutral-600 px-4 py-2 text-sm font-medium text-neutral-200 hover:bg-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-500">
      Log in
    </button>
  </form>

  <div class="mt-6 text-sm text-neutral-400 space-y-2">
    <p>Don't have an account? <a href="/signup" class="text-neutral-200 underline hover:text-neutral-100">Sign up</a></p>
    <p><a href="/forgotten-password" class="text-neutral-200 underline hover:text-neutral-100">Forgotten your password?</a></p>
  </div>
</div>
