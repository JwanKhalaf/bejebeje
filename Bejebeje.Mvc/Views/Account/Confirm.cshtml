@model Bejebeje.Models.Account.ConfirmViewModel

@{
  ViewData["Title"] = "Confirm email";
  ViewData["Description"] = "Confirm your email address";
}

<div class="py-5 pr-4 mb-6">
  <nav class="text-neutral-200 opacity-70 uppercase text-base">
    / Confirm email
  </nav>
</div>

<div class="pr-4 lg:pr-8 mb-8 max-w-md">
  <h1 class="font-lora text-neutral-200 text-3xl mb-2">
    Confirm your email
  </h1>

  <p class="text-neutral-400 text-sm mb-6">
    We've sent a confirmation code to your email. Enter it below to verify your account.
  </p>

  @if (!string.IsNullOrEmpty(Model.SuccessMessage))
  {
    <div class="rounded-md bg-green-900/50 border border-green-700 p-4 mb-6">
      <p class="text-sm text-green-200">@Model.SuccessMessage</p>
    </div>
  }

  @if (!string.IsNullOrEmpty(Model.ErrorMessage))
  {
    <div class="rounded-md bg-red-900/50 border border-red-700 p-4 mb-6">
      <p class="text-sm text-red-200">@Model.ErrorMessage</p>
    </div>
  }

  <form method="post" asp-action="Confirm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Email" value="@Model.Email" />

    <div class="mb-6">
      <label for="code" class="block text-sm font-medium text-neutral-300 mb-1">Confirmation code</label>
      <input type="text" id="code" name="Code" value="@Model.Code" required autocomplete="one-time-code"
             class="w-full rounded-md bg-neutral-700 border border-neutral-600 text-neutral-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-neutral-500 focus:border-transparent" />
    </div>

    <button type="submit"
            class="w-full rounded-md bg-neutral-600 px-4 py-2 text-sm font-medium text-neutral-200 hover:bg-neutral-500 focus:outline-none focus:ring-2 focus:ring-neutral-500">
      Confirm
    </button>
  </form>

  <form method="post" asp-action="ResendCode" class="mt-4">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Email" value="@Model.Email" />

    <button type="submit"
            class="text-sm text-neutral-200 underline hover:text-neutral-100">
      Resend code
    </button>
  </form>
</div>
