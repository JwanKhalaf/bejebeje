@using Humanizer
@model Bejebeje.Models.Lyric.LyricDetailsViewModel

@{
  ViewData["Title"] = $"{Model.Artist.FullName} - {Model.Title} lyrics";
  ViewData["Description"] = $"Lyrics for {Model.Title} by {Model.Artist.FullName}. Gotinê strana {Model.Title} ya {Model.Artist.FullName}. {Model.Title} sözleri - {Model.Artist.FullName}";
}

<div class="py-5 pr-4 mb-6">
  <nav class="text-neutral-200 opacity-70 uppercase text-base">
    <a asp-controller="Lyric" asp-action="ArtistLyrics"
       asp-route-artistSlug="@Model.Artist.PrimarySlug">/ @Model.Artist.FullName</a> / @Model.Title
  </nav>
</div>

@await Html.PartialAsync("_SearchForm")

@if (!Model.IsApproved)
{
  <div class="rounded-md bg-yellow-900/50 border border-yellow-700 p-4 mb-4 pr-4 lg:pr-8">
    <p class="text-sm font-medium text-yellow-200">Your submission is awaiting approval.</p>
  </div>
}

<a asp-controller="Lyric" asp-action="ArtistLyrics" asp-route-artistSlug="@Model.Artist.PrimarySlug"
   class="block mb-8 pr-4 lg:pr-8">
  <div class="flex gap-5 items-center bg-neutral-700 rounded-sm p-4">
    <picture>
      <source type="image/webp" srcset=@($"{Model.Artist.ImageUrl}.webp")>
      <source type="image/jpeg" srcset=@($"{Model.Artist.ImageUrl}.jpg")>

      <img class="rounded-full border border-neutral-500"
           src=@($"{Model.Artist.ImageUrl}.jpg")
           alt="@Model.Artist.ImageAlternateText"
           width="100"
           height="100"/>
    </picture>

    <div>
      <h1 class="text-neutral-200 font-open-sans uppercase">@Model.Artist.FullName</h1>
    </div>
  </div>
</a>

<div>
  <div>
    <h1 class="font-lora text-neutral-200 text-4xl mb-2">@Model.Title</h1>

    <div>
      <div class="flex gap-2 items-center">
        <p class="font-open-sans text-neutral-200 text-sm">
          <span class="opacity-70">By:</span>
          @if (!string.IsNullOrEmpty(Model.SubmitterProfileUrl))
          {
            <a href="@Model.SubmitterProfileUrl" class="text-amber-400 hover:text-amber-300 transition-colors">@Model.SubmitterUsername</a>
            <span class="text-neutral-500 text-xs ml-1">@(((double)Model.SubmitterPoints).ToMetric(decimals: 1)) BB · @Model.SubmitterLabel</span>
          }
          else
          {
            @Model.SubmitterUsername
          }
        </p>
      </div>
    </div>
  </div>

  <div class="flex justify-between pr-4 lg:pr-8">
    <div class="mb-8">
      <div class="text-neutral-200 font-lora whitespace-pre-line mb-8">
        @Model.Body
      </div>

      @if (Model.Author.Id != null)
      {
        <a asp-controller="Author" asp-action="Get" asp-route-authorSlug="@Model.Author.PrimarySlug" class="bg-neutral-700 p-4 flex items-center gap-2 rounded-sm">
          <i class="fa-solid fa-pen-nib text-neutral-400"></i>
          <h6 class="text-neutral-200 font-semibold font-open-sans">
            <span class="text-neutral-400">Lyrics by:</span> @Model.Author.FullName
          </h6>
        </a>
      }
    </div>

    <div class="flex flex-col gap-4">
      @if (Model.IsVerified)
      {
        <svg viewBox="0 0 640 640" class="size-10 lg:size-8 text-blue-500" fill="currentColor" title="Verified for accuracy">
          <path d="M320 64C356.8 64 388.8 84.7 404.9 115.1C437.8 105 475 112.9 501 139C527 165.1 535 202.3 524.9 235.2C555.3 251.2 576 283.2 576 320C576 356.8 555.3 388.8 524.9 404.9C535 437.8 527 475 501 501C475 527 437.7 535 404.8 524.9C388.8 555.3 356.8 576 320 576C283.2 576 251.2 555.3 235.1 524.9C202.2 535 165 527 139 501C113 475 105 437.7 115.1 404.8C84.7 388.8 64 356.8 64 320C64 283.2 84.7 251.2 115.1 235.1C105 202.2 112.9 165 139 139C165.1 113 202.3 105 235.2 115.1C251.2 84.7 283.2 64 320 64zM410.9 228.6C400.2 220.8 385.2 223.2 377.4 233.9L291.8 351.6L265.3 324.2C256.1 314.7 240.9 314.4 231.4 323.6C221.9 332.8 221.6 348 230.8 357.5L277.2 405.5C282.1 410.6 289 413.3 296.1 412.8C303.2 412.3 309.7 408.7 313.9 403L416.2 262.1C424 251.4 421.6 236.4 410.9 228.6z"/>
        </svg>
      }

      <div class="flex flex-col items-center justify-center">
        @if (Model.AlreadyLiked)
        {
          <svg viewBox="0 0 640 640" class="size-10 lg:size-8 text-red-400" fill="currentColor" title="Lyric likes">
            <path d="M305 151.1L320 171.8L335 151.1C360 116.5 400.2 96 442.9 96C516.4 96 576 155.6 576 229.1L576 231.7C576 343.9 436.1 474.2 363.1 529.9C350.7 539.3 335.5 544 320 544C304.5 544 289.2 539.4 276.9 529.9C203.9 474.2 64 343.9 64 231.7L64 229.1C64 155.6 123.6 96 197.1 96C239.8 96 280 116.5 305 151.1z"/>
          </svg>
        }
        else
        {
          <a asp-controller="Lyric"
             asp-action="Like"
             asp-route-artistSlug="@Model.Artist.PrimarySlug"
             asp-route-lyricSlug="@Model.PrimarySlug"
             asp-route-lyricId="@Model.Id">
            <svg viewBox="0 0 640 640" class="size-10 lg:size-8 text-neutral-500" fill="currentColor">
              <path d="M305 151.1L320 171.8L335 151.1C360 116.5 400.2 96 442.9 96C516.4 96 576 155.6 576 229.1L576 231.7C576 343.9 436.1 474.2 363.1 529.9C350.7 539.3 335.5 544 320 544C304.5 544 289.2 539.4 276.9 529.9C203.9 474.2 64 343.9 64 231.7L64 229.1C64 155.6 123.6 96 197.1 96C239.8 96 280 116.5 305 151.1z"/>
            </svg>
          </a>
        }

        <p class="text-neutral-500 font-bold font-lora text-xl">@Model.NumberOfLikes</p>
      </div>

      @if (Model.IsApproved)
      {
        <a href="/artists/@Model.Artist.PrimarySlug/lyrics/@Model.PrimarySlug/report" title="Report a problem with this lyric">
          <svg viewBox="0 0 640 640" class="size-10 lg:size-8 text-neutral-500" fill="currentColor">
            <path d="M160 96C160 78.3 145.7 64 128 64C110.3 64 96 78.3 96 96L96 544C96 561.7 110.3 576 128 576C145.7 576 160 561.7 160 544L160 422.4L222.7 403.6C264.6 391 309.8 394.9 348.9 414.5C391.6 435.9 441.4 438.5 486.1 421.7L523.2 407.8C535.7 403.1 544 391.2 544 377.8L544 130.1C544 107.1 519.8 92.1 499.2 102.4L487.4 108.3C442.5 130.8 389.6 130.8 344.6 108.3C308.2 90.1 266.3 86.5 227.4 98.2L160 118.4L160 96z"/>
          </svg>
        </a>
      }
    </div>
  </div>
</div>