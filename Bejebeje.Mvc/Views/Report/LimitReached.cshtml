@model Bejebeje.Models.Report.LyricReportLimitReachedViewModel

@{
  ViewData["Title"] = "Daily report limit reached";
  ViewData["Description"] = "You have reached your maximum number of reports for today";
}

<div class="py-5 pr-4 mb-6">
  <nav class="text-neutral-200 opacity-70 uppercase text-base">
    <a href="/artists/@Model.ArtistSlug/lyrics/@Model.LyricSlug">/ @Model.LyricTitle</a> / Report
  </nav>
</div>

<div class="pr-4 lg:pr-8">
  <div class="rounded-md bg-yellow-900/50 border border-yellow-700 p-6 mb-6">
    <div class="flex gap-3 items-start">
      <svg viewBox="0 0 640 640" class="size-6 text-yellow-400 shrink-0 mt-0.5" fill="currentColor">
        <path d="M320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64zM320 160C333.3 160 344 170.7 344 184L344 344C344 357.3 333.3 368 320 368C306.7 368 296 357.3 296 344L296 184C296 170.7 306.7 160 320 160zM320 416C338.5 416 353.5 431 353.5 449.5C353.5 468 338.5 483 320 483C301.5 483 286.5 468 286.5 449.5C286.5 431 301.5 416 320 416z"/>
      </svg>
      <div>
        <h1 class="font-lora text-yellow-200 text-2xl mb-2">Daily limit reached</h1>
        <p class="text-neutral-300 font-open-sans text-sm">
          You have reached your maximum of 3 reports for today. Please try again tomorrow.
        </p>
      </div>
    </div>
  </div>

  <a href="/artists/@Model.ArtistSlug/lyrics/@Model.LyricSlug"
     class="inline-block px-6 py-2 bg-neutral-700 text-neutral-200 text-sm font-medium rounded-sm hover:bg-neutral-600 transition-colors">
    Go back to lyric
  </a>
</div>
