@model Bejebeje.Models.Report.LyricReportViewModel

@{
  ViewData["Title"] = $"Report: {Model.LyricTitle} by {Model.ArtistName}";
  ViewData["Description"] = $"Report an issue with the lyrics for {Model.LyricTitle} by {Model.ArtistName}";
}

<div class="py-5 pr-4 mb-6">
  <nav class="text-neutral-200 opacity-70 uppercase text-base">
    <a href="/artists/@Model.ArtistSlug/lyrics">/ @Model.ArtistName</a> /
    <a href="/artists/@Model.ArtistSlug/lyrics/@Model.LyricSlug">@Model.LyricTitle</a> / Report
  </nav>
</div>

<div class="pr-4 lg:pr-8">
  <h1 class="font-lora text-neutral-200 text-3xl mb-2">Report a problem</h1>
  <p class="text-neutral-400 font-open-sans text-sm mb-6">
    <span class="font-semibold text-neutral-200">@Model.LyricTitle</span> by
    <span class="font-semibold text-neutral-200">@Model.ArtistName</span>
  </p>

  @if (Model.HasPendingReport)
  {
    <div class="rounded-md bg-yellow-900/50 border border-yellow-700 p-4 mb-4">
      <div class="flex gap-3 items-start">
        <svg viewBox="0 0 576 576" class="size-5 text-yellow-400 shrink-0 mt-0.5" fill="currentColor">
          <path d="M288 32C144.7 32 28 130.5 28 252C28 292.1 41.4 329.6 64 362.2L64 544L174.5 476.8C210.6 493 251.4 502 294.8 502C426.1 488.1 548 393 548 252C548 130.5 431.3 32 288 32z"/>
        </svg>
        <div>
          <h3 class="text-sm font-medium text-yellow-200">Already reported</h3>
          <p class="text-sm text-yellow-300/80 mt-1">
            You've already reported this lyric. We're reviewing it.
          </p>
          <a href="/artists/@Model.ArtistSlug/lyrics/@Model.LyricSlug"
             class="inline-block mt-3 text-sm font-medium text-yellow-200 underline hover:text-yellow-100">
            Go back to lyric
          </a>
        </div>
      </div>
    </div>
  }
  else
  {
    <div class="mb-6">
      <h2 class="text-neutral-300 font-open-sans text-sm uppercase tracking-wider mb-2">Lyric text</h2>
      <div class="bg-neutral-700 rounded-sm p-4 max-h-48 overflow-y-auto text-neutral-200 font-lora whitespace-pre-line text-sm">
        @Model.LyricBody
      </div>
    </div>

    <form method="post"
          action="/artists/@Model.ArtistSlug/lyrics/@Model.LyricSlug/report"
          class="space-y-5">
      @Html.AntiForgeryToken()

      <input type="hidden" name="LyricId" value="@Model.LyricId" />
      <input type="hidden" name="ArtistSlug" value="@Model.ArtistSlug" />
      <input type="hidden" name="LyricSlug" value="@Model.LyricSlug" />

      <div>
        <label for="Category" class="block text-sm font-medium text-neutral-300 mb-1">
          What's the problem?
        </label>
        <select id="Category" name="Category" required
                class="w-full rounded-sm bg-neutral-700 border border-neutral-600 text-neutral-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
          <option value="" disabled selected>Select a reason</option>
          <option value="0">Lyrics are not in Kurdish</option>
          <option value="1">Lyrics contain mistakes</option>
          <option value="2">Duplicate</option>
          <option value="3">Wrong artist</option>
          <option value="4">Offensive or inappropriate content</option>
        </select>
      </div>

      <div>
        <label for="Comment" class="block text-sm font-medium text-neutral-300 mb-1">
          Additional details (optional)
        </label>
        <textarea id="Comment" name="Comment" maxlength="2000" rows="4"
                  class="w-full rounded-sm bg-neutral-700 border border-neutral-600 text-neutral-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-y"
                  placeholder="Provide any extra context that might help us review this lyric..."></textarea>
        <p class="text-xs text-neutral-500 mt-1">
          <span id="comment-char-count">0</span> / 2000 characters
        </p>
      </div>

      <button type="submit"
              class="w-full sm:w-auto px-6 py-2 bg-blue-600 text-white text-sm font-medium rounded-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-neutral-800 transition-colors">
        Submit report
      </button>
    </form>
  }
</div>

@section Scripts {
  <script>
    (function () {
      const textarea = document.getElementById('Comment');
      const counter = document.getElementById('comment-char-count');

      if (textarea && counter) {
        textarea.addEventListener('input', function () {
          counter.textContent = textarea.value.length;
        });
      }
    })();
  </script>
}
