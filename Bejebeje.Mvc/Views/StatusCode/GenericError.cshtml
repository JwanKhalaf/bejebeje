@model int
@{
  Layout = "_ErrorLayout";
  ViewData["Title"] = "Something went wrong";

  (string title, string message) = Model switch
  {
    401 => ("You need to sign in", "This page requires you to be signed in. Head to the home page and sign in to continue."),
    403 => ("Access denied", "You don't have permission to view this page."),
    408 => ("Request timed out", "The request took too long. Give it another try."),
    503 => ("We're doing some maintenance", "We're making some improvements. Please check back in a few minutes."),
    _ => ("Something went wrong", "We're not sure what happened. Try heading back to the home page.")
  };
}

<main class="grid min-h-full place-items-center px-6 py-24">
  <div class="flex flex-col items-center text-center">
    <p class="text-base font-semibold text-amber-400">@Model</p>
    <h1 class="mt-4 text-5xl font-semibold tracking-tight text-neutral-200">
      @title
    </h1>

    <p class="mt-6 text-lg text-neutral-400">
      @message
    </p>

    <div class="mt-10 flex items-center justify-center gap-x-6">
      <a href="/"
         class="rounded-md bg-amber-500 px-4 py-2.5 text-sm font-semibold text-neutral-900 hover:bg-amber-400 transition-colors">
        Go home
      </a>

      <button type="button"
              onclick="history.back()"
              class="text-sm font-semibold text-neutral-200 hover:text-amber-400 transition-colors cursor-pointer">
        Go back <span aria-hidden="true">&rarr;</span>
      </button>
    </div>
  </div>
</main>
